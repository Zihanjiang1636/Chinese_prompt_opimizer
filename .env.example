# Default OpenAI-compatible setup
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1

# Example local presets
# Ollama: LLM_PROVIDER=openai-compatible / LLM_BASE_URL=http://127.0.0.1:11434/v1
# LM Studio: LLM_PROVIDER=openai-compatible / LLM_BASE_URL=http://127.0.0.1:1234/v1

HOST=127.0.0.1
PORT=8008
ALLOWED_CORS_ORIGINS=http://127.0.0.1:8008,http://localhost:8008
DEFAULT_USER_ID=local-user
